---
import { CATEGORY_ICONS, CATEGORY_ORDER, getCategoryLabel, SITE_TITLE } from '../consts';
---

<header>
	<nav>
		<a class="site-title" href="/">{SITE_TITLE}</a>

		<div class="nav-links" id="nav-links">
			{CATEGORY_ORDER.map((cat) => (
				<a href={`/${cat}/`} class="nav-link">
					<span class="material-symbols-outlined" aria-hidden="true">{CATEGORY_ICONS[cat] ?? 'article'}</span>
					{getCategoryLabel(cat)}
				</a>
			))}
		</div>

		<div class="header-right">
			<a href="https://x.com/kkk2jp" target="_blank" rel="noopener" aria-label="Twitter/X" class="social-link">
				<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
					<path d="M14.234 10.162 22.977 0h-2.072l-7.591 8.824L7.251 0H.258l9.168 13.343L.258 24H2.33l8.016-9.318L16.749 24h6.993zm-2.837 3.299-.929-1.329L3.076 1.56h3.182l5.965 8.532.929 1.329 7.754 11.09h-3.182z"/>
				</svg>
			</a>
			<a href="https://note.com/kkk2jp" target="_blank" rel="noopener" aria-label="note" class="social-link">
				<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
					<path d="M0 .279c4.623 0 10.953-.235 15.498-.117 6.099.156 8.39 2.813 8.468 9.374.077 3.71 0 14.335 0 14.335h-6.598c0-9.296.04-10.83 0-13.759-.078-2.578-.814-3.807-2.795-4.041-2.097-.235-7.975-.04-7.975-.04v17.84H0Z"/>
				</svg>
			</a>
			<button class="hamburger" id="hamburger" aria-label="メニューを開く" aria-expanded="false" aria-controls="mobile-menu">
				<span class="material-symbols-outlined" aria-hidden="true">menu</span>
			</button>
		</div>
	</nav>

	<div class="mobile-menu" id="mobile-menu" aria-hidden="true">
		{CATEGORY_ORDER.map((cat) => (
			<a href={`/${cat}/`} class="mobile-nav-link">
				<span class="material-symbols-outlined" aria-hidden="true">{CATEGORY_ICONS[cat] ?? 'article'}</span>
				{getCategoryLabel(cat)}
			</a>
		))}
	</div>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		background: var(--md-surface);
		border-bottom: 1px solid var(--md-outline-variant);
		/* mobile menuのabsolute基準点 */
		isolation: isolate;
	}
	nav {
		max-width: 960px;
		margin: auto;
		padding: 0 16px;
		height: 64px;
		display: flex;
		align-items: center;
		gap: 8px;
	}
	.site-title {
		font-size: 1.25rem;
		font-weight: 700;
		color: var(--md-on-surface);
		text-decoration: none;
		letter-spacing: -0.01em;
		margin-right: 8px;
		white-space: nowrap;
		flex-shrink: 0;
		padding-bottom: 4px;
	}
	.site-title:hover { color: var(--md-primary); text-decoration: none; }

	/* Desktop nav */
	.nav-links {
		display: flex;
		gap: 4px;
		flex: 1;
	}
	.nav-link {
		display: inline-flex;
		align-items: center;
		gap: 5px;
		padding: 8px 14px;
		border-radius: 9999px;
		font-size: 0.9375rem;
		font-weight: 500;
		color: var(--md-on-surface-variant);
		text-decoration: none;
		transition: background 0.15s, color 0.15s;
		white-space: nowrap;
		line-height: 1;
	}
	.nav-link .material-symbols-outlined {
		font-size: 16px;
		line-height: 1;
		vertical-align: middle;
	}
	.nav-link:hover { background: var(--md-surface-variant); color: var(--md-on-surface); text-decoration: none; }
	.nav-link[aria-current] { background: var(--md-primary-container); color: var(--md-on-primary-container); font-weight: 700; }

	/* Right side */
	.header-right {
		display: flex;
		align-items: center;
		gap: 4px;
		flex-shrink: 0;
	}
	.social-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 36px;
		height: 36px;
		border-radius: 9999px;
		color: var(--md-on-surface-variant);
		transition: background 0.15s, color 0.15s;
	}
	.social-link:hover { background: var(--md-surface-variant); color: var(--md-on-surface); text-decoration: none; }

	/* Hamburger — mobile only */
	.hamburger {
		display: none;
		align-items: center;
		justify-content: center;
		width: 36px;
		height: 36px;
		border: none;
		background: transparent;
		border-radius: 9999px;
		cursor: pointer;
		color: var(--md-on-surface-variant);
		transition: background 0.15s;
	}
	.hamburger .material-symbols-outlined { font-size: 22px; line-height: 1; }
	.hamburger:hover { background: var(--md-surface-variant); }

	/* Mobile menu — overlay */
	.mobile-menu {
		display: none;
		position: absolute;
		top: 64px;
		left: 0;
		right: 0;
		flex-direction: column;
		padding: 8px 16px 16px;
		background: var(--md-surface);
		border-bottom: 1px solid var(--md-outline-variant);
		box-shadow: 0 8px 24px rgba(0,0,0,.1);
		z-index: 200;
	}
	.mobile-menu.open { display: flex; }
	.mobile-nav-link {
		display: flex;
		align-items: center;
		gap: 12px;
		padding: 12px 8px;
		border-radius: 12px;
		font-size: 0.9375rem;
		font-weight: 500;
		color: var(--md-on-surface);
		text-decoration: none;
		transition: background 0.15s;
	}
	.mobile-nav-link .material-symbols-outlined { font-size: 20px; color: var(--md-primary); }
	.mobile-nav-link:hover { background: var(--md-surface-variant); text-decoration: none; }

	@media (max-width: 640px) {
		.nav-links { display: none; }
		.hamburger { display: inline-flex; }
		nav { justify-content: space-between; height: 64px; }
		.mobile-menu { top: 64px; }
	}
</style>

<script>
	const btn = document.getElementById('hamburger');
	const menu = document.getElementById('mobile-menu');

	function closeMenu() {
		menu?.classList.remove('open');
		btn?.setAttribute('aria-expanded', 'false');
		btn?.setAttribute('aria-label', 'メニューを開く');
		const icon = btn?.querySelector('.material-symbols-outlined');
		if (icon) icon.textContent = 'menu';
	}

	btn?.addEventListener('click', (e) => {
		e.stopPropagation();
		const isOpen = menu?.classList.toggle('open');
		btn.setAttribute('aria-expanded', String(isOpen));
		btn.setAttribute('aria-label', isOpen ? 'メニューを閉じる' : 'メニューを開く');
		const icon = btn.querySelector('.material-symbols-outlined');
		if (icon) icon.textContent = isOpen ? 'close' : 'menu';
	});

	document.addEventListener('click', (e) => {
		if (menu?.classList.contains('open') && !menu.contains(e.target as Node)) {
			closeMenu();
		}
	});
</script>
