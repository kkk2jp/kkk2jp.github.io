---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { CATEGORY_ICONS, CATEGORY_ORDER, getCategoryLabel, SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const postsByCategory = Object.fromEntries(
	CATEGORY_ORDER.map((cat) => [
		cat,
		allPosts.filter((p) => p.data.category === cat).slice(0, 5),
	]),
);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main { width: 960px; }

			.category-section { margin-bottom: 48px; }

			.category-section-header {
				display: flex;
				align-items: center;
				justify-content: space-between;
				margin-bottom: 16px;
				padding-bottom: 12px;
				border-bottom: 2px solid var(--md-primary);
			}
			.category-section-header h2 {
				margin: 0;
				font-size: 1.25rem;
				font-weight: 700;
			}
			.category-section-header a.more {
				font-size: 0.875rem;
				color: var(--md-primary);
				text-decoration: none;
				font-weight: 500;
			}
			.category-section-header a.more:hover { text-decoration: underline; }

			@media (max-width: 720px) {
				.post-list .post-thumb { width: 56px; height: 42px; }
				.post-list .post-thumb .material-symbols-outlined { font-size: 22px; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			{CATEGORY_ORDER.map((cat) => (
				<section class="category-section">
					<div class="category-section-header">
						<h2>{getCategoryLabel(cat)}</h2>
						<a class="more" href={`/${cat}/`}>すべて見る →</a>
					</div>
					<ul class="post-list">
						{postsByCategory[cat].map((post) => {
							const parts = post.id.split('/');
							const slug = parts.slice(1).join('/');
							return (
								<li>
									<a href={`/${cat}/${slug}/`}>
										<div class="post-thumb">
											<span class="material-symbols-outlined" aria-hidden="true">
												{CATEGORY_ICONS[cat] ?? 'article'}
											</span>
										</div>
										<div class="post-info">
											<h3>{post.data.title}</h3>
											<p class="date"><FormattedDate date={post.data.pubDate} /></p>
										</div>
									</a>
								</li>
							);
						})}
					</ul>
				</section>
			))}
		</main>
		<Footer />
	</body>
</html>
