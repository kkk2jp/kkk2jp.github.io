---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { CATEGORY_ICONS, getCategoryLabel, SITE_TITLE } from '../../consts';

export async function getStaticPaths() {
	const PAGE_SIZE = 10;
	const posts = await getCollection('blog');
	const categories = [...new Set(posts.map((p) => p.data.category))];

	return categories.flatMap((category) => {
		const catPosts = posts
			.filter((p) => p.data.category === category)
			.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
		const totalPages = Math.ceil(catPosts.length / PAGE_SIZE);
		return Array.from({ length: totalPages - 1 }, (_, i) => ({
			params: { category, pagenum: String(i + 2) },
			props: { posts: catPosts, totalPages },
		}));
	});
}

const { category, pagenum } = Astro.params;
const { posts, totalPages } = Astro.props;
const currentPage = Number(pagenum);
const label = getCategoryLabel(category);
const icon = CATEGORY_ICONS[category] ?? 'article';
const pagePosts = posts.slice((currentPage - 1) * PAGE_SIZE, currentPage * PAGE_SIZE);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead
			title={`${label} (${currentPage}ページ目) | ${SITE_TITLE}`}
			description={`${label}の記事一覧 ${currentPage}ページ目`}
		/>
		<style>
			main { width: 960px; }

			.back-link {
				display: inline-flex;
				align-items: center;
				gap: 4px;
				margin-bottom: 24px;
				color: var(--md-primary);
				text-decoration: none;
				font-size: 0.875rem;
				font-weight: 500;
			}
			.back-link:hover { text-decoration: underline; }

			.category-header {
				margin-bottom: 24px;
				padding-bottom: 16px;
				border-bottom: 2px solid var(--md-primary);
			}
			.category-header h1 {
				font-size: 1.75rem;
				font-weight: 700;
				margin: 0 0 4px;
			}
			.category-header p {
				color: var(--md-on-surface-variant);
				font-size: 0.875rem;
				margin: 0;
			}

.pagination {
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 8px;
			}
			.pagination a,
			.pagination span {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				min-width: 36px;
				height: 36px;
				padding: 0 8px;
				border-radius: 9999px;
				font-size: 0.875rem;
				font-weight: 500;
				text-decoration: none;
				color: var(--md-on-surface-variant);
				transition: background 0.15s;
			}
			.pagination a:hover { background: var(--md-surface-variant); }
			.pagination .current {
				background: var(--md-primary);
				color: var(--md-on-primary);
			}
			.pagination .disabled {
				opacity: 0.3;
				pointer-events: none;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<a class="back-link" href="/">← トップに戻る</a>
			<div class="category-header">
				<h1>{label}</h1>
				<p>{posts.length}件の記事</p>
			</div>

			<ul class="post-list">
				{pagePosts.map((post) => {
					const parts = post.id.split('/');
					const slug = parts.slice(1).join('/');
					return (
						<li>
							<a href={`/${category}/${slug}/`}>
								<div class="post-thumb">
									<span class="material-symbols-outlined" aria-hidden="true">{icon}</span>
								</div>
								<div class="post-info">
									<h2>{post.data.title}</h2>
									<p class="date"><FormattedDate date={post.data.pubDate} /></p>
								</div>
							</a>
						</li>
					);
				})}
			</ul>

			<nav class="pagination" aria-label="ページネーション">
				{currentPage > 1
					? <a href={currentPage === 2 ? `/${category}/` : `/${category}/${currentPage - 1}/`}>← 前へ</a>
					: <span class="disabled">← 前へ</span>
				}
				{Array.from({ length: totalPages }, (_, i) => i + 1).map((p) =>
					p === currentPage
						? <span class="current">{p}</span>
						: <a href={p === 1 ? `/${category}/` : `/${category}/${p}/`}>{p}</a>
				)}
				{currentPage < totalPages
					? <a href={`/${category}/${currentPage + 1}/`}>次へ →</a>
					: <span class="disabled">次へ →</span>
				}
			</nav>
		</main>
		<Footer />
	</body>
</html>
